---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectGrid from '../../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<BaseLayout title="Projects — Portfolio" description="Browse all my projects by type and technology.">
  <section class="section container">
    <h1 class="section-title">All Projects</h1>
    <p class="section-subtitle">Filter by type to find what interests you.</p>
    <ProjectGrid projects={sortedProjects} showFilters={true} />
  </section>
</BaseLayout>

<style>
  .section-subtitle {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xl);
    margin-top: calc(-1 * var(--space-md));
  }
</style>
