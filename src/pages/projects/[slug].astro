---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} — Portfolio`} description={project.data.description}>
  <article class="section container project-detail">
    <a href="/projects" class="back-link">&larr; Back to Projects</a>

    <header class="project-header">
      <span class="project-type">{project.data.type}</span>
      <h1>{project.data.title}</h1>
      <p class="project-description">{project.data.description}</p>
      <div class="project-tags">
        {project.data.tags.map((tag: string) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
      <div class="project-links">
        {project.data.liveUrl && (
          <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Live Demo
          </a>
        )}
        {project.data.repoUrl && (
          <a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
            Source Code
          </a>
        )}
      </div>
    </header>

    <div class="project-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .project-detail {
    max-width: 800px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-xl);
    font-weight: 500;
    font-size: 0.9rem;
  }

  .project-header {
    margin-bottom: var(--space-2xl);
  }

  .project-type {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
  }

  .project-header h1 {
    font-size: 2.25rem;
    font-weight: 700;
    margin: var(--space-sm) 0 var(--space-md);
  }

  .project-description {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-lg);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .tag {
    font-size: 0.8rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    background-color: var(--color-tag-bg);
    color: var(--color-tag-text);
    font-weight: 500;
  }

  .project-links {
    display: flex;
    gap: var(--space-md);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.25rem;
    border-radius: var(--border-radius);
    font-weight: 600;
    font-size: 0.9rem;
    transition: all var(--transition-fast);
  }

  .btn-primary {
    background-color: var(--color-accent);
    color: white;
  }

  .btn-primary:hover {
    background-color: var(--color-accent-hover);
    color: white;
  }

  .btn-outline {
    border: 2px solid var(--color-border);
    color: var(--color-text);
  }

  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .project-content {
    line-height: 1.8;
  }

  .project-content :global(h2) {
    font-size: 1.5rem;
    margin: var(--space-2xl) 0 var(--space-md);
  }

  .project-content :global(p) {
    margin-bottom: var(--space-md);
    color: var(--color-text-secondary);
  }

  .project-content :global(ul) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-lg);
  }

  .project-content :global(li) {
    margin-bottom: var(--space-sm);
    color: var(--color-text-secondary);
  }

  .project-content :global(pre) {
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    padding: var(--space-lg);
    overflow-x: auto;
    margin-bottom: var(--space-md);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .project-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }
</style>
